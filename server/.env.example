# ============================================================
# GyanKosh Server — Environment Variables (EXAMPLE)
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

NODE_ENV=development
PORT=5000

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/gyankosh

# ── JWT (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_ACCESS_SECRET=<64-char-random-hex>
JWT_REFRESH_SECRET=<64-char-random-hex-different>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Cookie signing ────────────────────────────────────────────────────────────
COOKIE_SECRET=<32-char-random-string>

# ── AES-256 encryption (exactly 32 chars) ────────────────────────────────────
ENCRYPTION_KEY=<exactly-32-chars>

# ── Stripe (https://dashboard.stripe.com/test/apikeys) ───────────────────────
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ── Email / SMTP ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
EMAIL_FROM=GyanKosh <your-email@gmail.com>
EMAIL_SEND_IN_DEVELOPMENT=true
# Where honeytoken/intrusion alerts are sent (falls back to SMTP_USER if unset)
ADMIN_ALERT_EMAIL=security-team@example.com

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=GyanKosh
FRONTEND_URL=http://localhost:3000

# ── Google reCAPTCHA v3 ───────────────────────────────────────────────────────
RECAPTCHA_SECRET_KEY=key-from-google


# ── Rate limiting ─────────────────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_MS=900000

# ── IP Allowlist (comma-separated, bypass rate limiting in dev) ───────────────
IP_ALLOWLIST=127.0.0.1,::1

GOOGLE_CLIENT_ID=googleclientid.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=googleclientsecret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback